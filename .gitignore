# 环境变量（含 API Key，绝不提交）
.env

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# IDE
.vscode/
.idea/
*.swp
*.swo

# 输入数据（PDF 等大文件，不入库，保留在本地）
input/

# 输出目录（运行时生成）
output/

# 临时文件
temp_*/
*.tmp
_tmp_*/

# Claude Code worktrees（会话临时副本，不入库）
.claude/worktrees/

# Claude Code 运行时（不入库）
.claude/scheduled_tasks.lock
.claude/settings.local.json
.claude/settings.json

# 历史 plan 文档（不入库）
*plan*.md

# 调试输出（不入库）
_debug_*.json

