# LLM 配置（兼容 OpenAI / DeepSeek 等 API）
# DeepSeek 示例：
#   LLM_API_KEY=sk-your-key-here
#   LLM_BASE_URL=https://api.deepseek.com
#   LLM_MODEL=deepseek-chat
#
# OpenAI 示例：
#   LLM_API_KEY=sk-your-key-here
#   LLM_BASE_URL=https://api.openai.com/v1
#   LLM_MODEL=gpt-5.4
#
# 旧版环境变量（兼容，会被以上新变量覆盖）：
#   OPENAI_API_KEY=sk-你的密钥放这里
#   OPENAI_MODEL=gpt-5.4

LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# LLM 精炼参数（可选，以下为默认值）
LLM_STRUCTURE_REFINE_ROUNDS=2
LLM_STRUCTURE_REFINE_CANDIDATES=12

# OCR 软超时（秒），超过后保留已完成页结果并提前停止。留空则使用 OCR_TIMEOUT_SECONDS 的值
# OCR_SOFT_TIMEOUT_SECONDS=
